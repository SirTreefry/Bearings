#n shaft rotational speed
#N number of rolling elements
#B_d diameter of rolling element
#P_d pitch diameter
#Phi Contact angle


N = 16
n = 2000
B_d = .331
P_d = 2.8915
phi = 15.17*math.pi/180



#=============================================
#Bearing Fundamentall Frequencies
#=============================================
#(BPFI) Ball Pass Frequency Inner
#(BPFO) Ball Pass frequency Outer
#(BSF) Ball Spin Frequency
#(FTF) Fudamental Train Frequency

BPFI = (N/2)*(1 + B_d/P_d * np.cos(phi))*n

BPFO = (N/2)*(1 - B_d/P_d * np.cos(phi))*n

BSF = (P_d/(2*B_d))*(1 - ((B_d/P_d)*np.cos(phi))**2)*n

FTF = (1/2)*(1 - (B_d/P_d)*np.cos(phi))*n

print("BPFI=%d" % (BPFI))
print("BPFO=%d" % (BPFO))
print("BSF=%d" % (BSF))
print("FTF=%d" % (FTF))



